{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "allowJs": true,
    "noEmit": true,
    "jsx": "react",
    "lib": ["dom", "es2015", "es2017"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "stripInternal": true,
    "baseUrl": ".",
    "paths": {
      "@common/*":  ["./src/common/*"],
      "@modules/*":  ["./src/modules/*"],
      "@components/*":  ["./src/components/*"],
      "@static/*": ["./src/static/*"],
      "@exampleData/*": ["./src/exampleData/*"],
    },
  },
  "exclude": [
    "node_modules",
    "public",
    ".cache",
    "./gatsby-config.js",
    "./gatsby-node.js",
    "./gatsby-browser.js",
    "./gatsby-ssr.js"
  ],
  "include": ["./src/**/*"]
}
